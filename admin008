    };

    return (
      <div className="animate-fadeIn px-4 md:px-6 pb-6">
        <h2 className="text-xl font-black mb-6"><HeartPulse className="text-blue-500 inline ml-2"/>إدارة الأطباء</h2>
        <form onSubmit={handleSubmit} className="glass-panel p-5 rounded-3xl mb-8 flex flex-col gap-4">
          <div className="flex justify-between">{editingId&&<button type="button" onClick={resetForm} className="text-xs bg-slate-100 px-3 py-1 rounded-lg">إلغاء</button>}<h3 className="font-bold text-blue-600 flex items-center gap-2"><Plus size={18}/>{editingId?'تعديل':'إضافة جديد'}</h3></div>
          <input type="text" placeholder="اسم الطبيب" value={name} onChange={e=>setName(e.target.value)} className="custom-input p-3 rounded-xl" required/>
          <input type="text" placeholder="الاختصاص" value={specialty} onChange={e=>setSpecialty(e.target.value)} className="custom-input p-3 rounded-xl" required/>
          <input type="text" placeholder="العنوان" value={address} onChange={e=>setAddress(e.target.value)} className="custom-input p-3 rounded-xl" required/>
          <input type="tel" placeholder="رقم الهاتف" value={phone} onChange={e=>setPhone(e.target.value)} className="custom-input p-3 rounded-xl" dir="ltr"/>
          <input type="url" placeholder="رابط الخريطة" value={mapLink} onChange={e=>setMapLink(e.target.value)} className="custom-input p-3 rounded-xl" dir="ltr"/>
          <button type="submit" disabled={loading} className="bg-blue-500 text-white p-3 rounded-xl font-bold disabled:opacity-50 flex justify-center gap-2">{loading?<Loader2 className="animate-spin"/>:editingId?<><Edit size={16}/>تحديث</>:'حفظ'}</button>
        </form>
        <div className="space-y-3">
          {safeDoctors.length===0 ? <p className="text-center py-10 text-slate-500">لا يوجد أطباء.</p> :
            safeDoctors.map(doc=>{
              const {average,count}=getRatingInfo(doc);
              return (
                <div key={doc.id} className="glass-panel p-4 rounded-2xl flex justify-between items-start">
                  <div className="flex flex-col gap-2">
                    <div className="flex gap-2">
                      <button onClick={()=>deleteDoctor(doc.id, doc.name||'طبيب')} className="p-2 bg-red-50 text-red-500 rounded-lg"><Trash2 size={16}/></button>
                      <button onClick={()=>handleEditClick(doc)} className="p-2 bg-blue-50 text-blue-500 rounded-lg"><Edit size={16}/></button>
                    </div>
                    {doc.mapLink&&<a href={doc.mapLink} target="_blank" className="p-2 bg-blue-50 text-blue-500 rounded-lg text-xs flex items-center gap-1"><Map size={14}/>الخريطة</a>}
                  </div>
                  <div className="text-right flex-1 pr-2">
                    <h4 className="font-black">{doc.name||'بدون اسم'}</h4>
                    <p className="text-xs text-blue-500 mt-1">{doc.specialty||'---'}</p>
                    <p className="text-xs text-slate-500"><MapPin size={10}/> {doc.address||'---'}</p>
                    {doc.phone&&<p className="text-xs" dir="ltr"><Phone size={10}/> {doc.phone}</p>}
                    <div className="mt-1 flex items-center justify-end gap-1 text-yellow-500 text-xs"><Star size={12} fill="currentColor"/><span dir="ltr">{average?average.toFixed(1):'0.0'} /5</span><span className="text-slate-400">({count})</span></div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    );
  }

  // ======================== AdminApp ========================
  function AdminApp() {
    const [user, setUser] = useState(null);
    const [view, setView] = useState('dashboard');
    const [donors, setDonors] = useState([]);
    const [pharmacies, setPharmacies] = useState([]);
    const [doctors, setDoctors] = useState([]);
    const [medicines, setMedicines] = useState([]);
    const [reports, setReports] = useState([]);
    const [notificationsLog, setNotificationsLog] = useState([]);
    const [adminRequests, setAdminRequests] = useState([]);
    const [notificationToast, setNotificationToast] = useState(null);
    const [modalConfig, setModalConfig] = useState({ isOpen: false });
    const [initializing, setInitializing] = useState(true);
    const [isDark, setIsDark] = useState(() => localStorage.getItem('theme_admin') === 'dark');

    useEffect(() => {
      document.documentElement.classList.toggle('dark', isDark);
      localStorage.setItem('theme_admin', isDark ? 'dark' : 'light');
    }, [isDark]);
    const toggleTheme = () => setIsDark(!isDark);

    useEffect(() => {
      const unsubscribe = onAuthStateChanged(auth, currentUser => { setUser(currentUser); if(initializing) setInitializing(false); });
      return () => unsubscribe();
    }, [initializing]);

    useEffect(() => {
      if (!user) return;
      const unsubDonors = onSnapshot(collection(db, DONORS_COLLECTION), snap => setDonors(snap.docs.map(d=>({id:d.id,...d.data()}))));
      const unsubPharm = onSnapshot(collection(db, PHARMACIES_COLLECTION), snap => setPharmacies(snap.docs.map(d=>({id:d.id,...d.data()}))));
      const unsubDoc = onSnapshot(collection(db, DOCTORS_COLLECTION), snap => setDoctors(sortDoctorsList(snap.docs.map(d=>({id:d.id,...d.data()})))));
      const unsubMed = onSnapshot(collection(db, MEDICINES_COLLECTION), snap => setMedicines(snap.docs.map(d=>({id:d.id,...d.data()}))));
      const unsubRep = onSnapshot(collection(db, REPORTS_COLLECTION), snap => setReports(snap.docs.map(d=>({id:d.id,...d.data()}))));
      const unsubNotif = onSnapshot(query(collection(db, NOTIFICATIONS_COLLECTION), orderBy('createdAt','desc')), snap => setNotificationsLog(snap.docs.map(d=>({id:d.id,...d.data()}))));
      const unsubRequests = onSnapshot(query(collection(db, ADMIN_REQUESTS_COLLECTION), orderBy('createdAt','desc')), snap => setAdminRequests(snap.docs.map(d=>({id:d.id,...d.data()}))));
      return () => { unsubDonors(); unsubPharm(); unsubDoc(); unsubMed(); unsubRep(); unsubNotif(); unsubRequests(); };
    }, [user]);

    const showNotification = (type, msg) => { setNotificationToast({type,msg}); setTimeout(()=>setNotificationToast(null),3000); };
    const closeConfirm = () => setModalConfig(p=>({...p,isOpen:false}));
    const confirmAction = (title, message, confirmText, action, isDestructive=false) => { setModalConfig({isOpen:true, title, message, confirmText, isDestructive, action: ()=>{ action(); closeConfirm(); }}); };

    if (initializing) return <div className="min-h-screen flex items-center justify-center"><Loader2 className="animate-spin text-indigo-500" size={48}/></div>;
    if (!user) {
      const handleLogin = async (e) => { e.preventDefault(); try { await signInWithEmailAndPassword(auth, e.target.email.value.trim(), e.target.password.value); } catch { alert('بيانات الدخول غير صحيحة'); } };
      return (
        <div className="min-h-screen flex items-center justify-center p-4 bg-slate-50 dark:bg-[#020617] relative">
          <button onClick={toggleTheme} className="absolute top-6 left-6 w-10 h-10 glass-panel rounded-full flex items-center justify-center">{isDark?<Sun size={20}/>:<Moon size={20}/>}</button>
          <form onSubmit={handleLogin} className="glass-panel p-8 rounded-[2rem] w-full max-w-sm flex flex-col gap-4">
            <div className="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mx-auto"><Lock size={32} className="text-indigo-600"/></div>
            <h2 className="text-2xl font-black text-center">دخول الإدارة</h2>
            <input name="email" type="email" placeholder="البريد الإلكتروني" className="custom-input p-4 rounded-xl text-center" required/>
            <input name="password" type="password" placeholder="كلمة المرور" className="custom-input p-4 rounded-xl text-center" required/>
            <button className="bg-indigo-500 text-white font-bold p-4 rounded-xl mt-2 hover:bg-indigo-600">تسجيل الدخول</button>
          </form>
        </div>
      );
    }

    return (
      <div className="min-h-screen pb-24 relative">
        <AdminHeader isDark={isDark} toggleTheme={toggleTheme} view={view} setView={setView} />
        <div className="w-full max-w-2xl mx-auto">
          {view === 'dashboard' && <DashboardView donors={donors} pharmacies={pharmacies} doctors={doctors} medicines={medicines} reports={reports} adminRequests={adminRequests} setView={setView} />}
          {view === 'pharmacies' && <PharmaciesManager pharmacies={pharmacies} showNotification={showNotification} confirmAction={confirmAction} />}
          {view === 'duty' && <DutyManager pharmacies={pharmacies} showNotification={showNotification} />}
          {view === 'doctors' && <DoctorsManager doctors={doctors} showNotification={showNotification} confirmAction={confirmAction} />}
          {view === 'requests' && <RequestsView adminRequests={adminRequests} showNotification={showNotification} confirmAction={confirmAction} />}
          {view === 'notifications' && <NotificationsLogView notifications={notificationsLog} donors={donors} showNotification={showNotification} />}
          {view === 'broadcast' && <BroadcastView donors={donors} showNotification={showNotification} confirmAction={confirmAction} />}
          {view === 'donors' && <DonorsManager donors={donors} showNotification={showNotification} confirmAction={confirmAction} />}
          {view === 'medicines' && <MedicinesManager medicines={medicines} showNotification={showNotification} confirmAction={confirmAction} />}
          {view === 'reports' && <ReportsManager reports={reports} showNotification={showNotification} confirmAction={confirmAction} />}
        </div>
        <AdminBottomNav view={view} setView={setView} />
        <Toast notification={notificationToast} />
        <CustomModal isOpen={modalConfig.isOpen} title={modalConfig.title} message={modalConfig.message} isDestructive={modalConfig.isDestructive} confirmText={modalConfig.confirmText} onCancel={closeConfirm} onConfirm={modalConfig.action} />
      </div>
    );
  }

  const root = createRoot(document.getElementById('root'));
  root.render(<AdminApp />);
</script>
</body>
</html>
