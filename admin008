        <div className="glass-panel rounded-3xl p-3 max-h-[65vh] overflow-y-auto no-scrollbar">
          {grouped.length === 0 ? <p className="text-center py-10 text-slate-500">لا يوجد نشاط.</p> :
            grouped.map(n => {
              const dateStr = n.createdAt?.toDate ? new Intl.DateTimeFormat('ar-DZ', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }).format(n.createdAt.toDate()) : '';
              const isGlobal = n.type === 'global'; const isReq = n.type === 'request'; const isReject = n.title?.includes('اعتذار');
              const fromName = safeDonors.find(d => d.id === n.fromUserId)?.username || (n.fromUserId === 'ADMIN' ? 'الإدارة' : 'مجهول');
              const toName = safeDonors.find(d => d.id === n.toUserId)?.username || 'مجهول';
              let icon = <Info size={16} className="text-blue-500"/>; let bg = 'bg-blue-50 border-blue-100'; let badge = null;
              if (isGlobal) { icon = <Bell size={16} className="text-purple-500"/>; bg = 'bg-purple-50 border-purple-100'; badge = <span className="bg-purple-500 text-white text-[10px] px-2 py-0.5 rounded-full">إعلان</span>; }
              else if (isReq) { icon = <Droplet size={16} className="text-orange-500"/>; bg = 'bg-orange-50 border-orange-100'; badge = <span className="bg-orange-500 text-white text-[10px] px-2 py-0.5 rounded-full">طلب تبرع</span>; }
              else if (isReject) { icon = <XCircle size={16} className="text-slate-500"/>; bg = 'bg-slate-100 border-slate-200'; badge = <span className="bg-slate-500 text-white text-[10px] px-2 py-0.5 rounded-full">اعتذار</span>; }

              return (
                <div key={n.id} className={`${bg} p-4 mb-3 border rounded-2xl text-right`}>
                  <div className="flex justify-between items-center">
                    <span className="text-[10px] text-slate-400">{dateStr}</span>
                    <div className="flex items-center gap-2">{badge}<div className="w-6 h-6 rounded-full bg-white flex items-center justify-center">{icon}</div></div>
                  </div>
                  {!isGlobal && (
                    <div className="bg-white/50 p-2 rounded-xl mt-2 flex items-center justify-between">
                      <div className="text-center"><span className="text-[9px] text-slate-400">المستقبل</span><p className="text-xs font-black">{toName}</p></div>
                      <ArrowLeft size={14} className="text-slate-300"/>
