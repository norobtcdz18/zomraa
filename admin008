<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Zomraa Admin - لوحة التحكم</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: { sans: ['Cairo', 'sans-serif'] },
          colors: { brand: { accent: '#818cf8', accentHover: '#6366f1' } }
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
  <script type="importmap">
    {
      "imports": {
        "react": "https://esm.sh/react@18.2.0",
        "react-dom/client": "https://esm.sh/react-dom@18.2.0/client",
        "firebase/app": "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js",
        "firebase/auth": "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js",
        "firebase/firestore": "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js",
        "lucide-react": "https://esm.sh/lucide-react@0.344.0"
      }
    }
  </script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <style>
    body {
      font-family: 'Cairo', sans-serif; transition: background 0.3s, color 0.3s;
      -webkit-tap-highlight-color: transparent; min-height: 100vh;
      padding-bottom: env(safe-area-inset-bottom); background: #F8FAFC; color: #1e293b;
    }
    .glass-panel { background: #ffffff; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
    .custom-input { background: #f8fafc; border: 1px solid #cbd5e1; color: #1e293b; }
    .custom-input::placeholder { color: #94a3b8; }
    html.dark body { background: linear-gradient(145deg, #0f172a 0%, #020617 100%); background-attachment: fixed; color: #f8fafc; }
    html.dark .glass-panel { background: rgba(30,41,59,0.7); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 10px 25px -5px rgba(0,0,0,0.3); }
    html.dark .custom-input { background: rgba(15,23,42,0.6); border: 1px solid rgba(255,255,255,0.1); color: #f8fafc; }
    html.dark .custom-input::placeholder { color: #64748b; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .animate-fadeIn { animation: fadeIn 0.3s ease-out forwards; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>
<div id="root"></div>
<script type="text/babel" data-type="module">
  import React, { useState, useEffect, useMemo } from 'react';
  import { createRoot } from 'react-dom/client';
  import { initializeApp } from 'firebase/app';
  import { getAuth, signInWithEmailAndPassword, onAuthStateChanged, signOut } from 'firebase/auth';
  import { getFirestore, collection, doc, setDoc, deleteDoc, onSnapshot, serverTimestamp, query, orderBy, updateDoc, addDoc } from 'firebase/firestore';
  import {
    Users, Stethoscope, Pill, ShieldAlert, LayoutDashboard, Plus, Trash2, CheckCircle2,
    AlertTriangle, Info, X, Activity, Bell, Send, Lock, Moon, Sun, LogOut, Loader2,
    Droplet, ArrowRight, ArrowLeft, Check, MapPin, Map, Calendar, Edit, XCircle, Phone,
    Clock, HeartPulse, Star, MessageSquare, Reply
  } from 'lucide-react';

  const firebaseConfig = {
    apiKey: "AIzaSyANXo96l5_hP1iTH_K8TaYixdGHJwr6x-0",
    authDomain: "blod-6a25b.firebaseapp.com",
    projectId: "blod-6a25b",
    storageBucket: "blod-6a25b.firebasestorage.app",
    messagingSenderId: "766563585970",
    appId: "1:766563585970:web:ad99353f2dbcbf759a1eab"
  };
  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const db = getFirestore(app);

  const DONORS_COLLECTION = "donors";
  const MEDICINES_COLLECTION = "medicines";
  const PHARMACIES_COLLECTION = "pharmacies";
  const DOCTORS_COLLECTION = "doctors";
  const REPORTS_COLLECTION = "reports";
  const NOTIFICATIONS_COLLECTION = "notifications";
  const ADMIN_REQUESTS_COLLECTION = "admin_requests";
  const DUTY_DATES_COLLECTION = "duty_dates";

  function getLocalDateString(date = new Date()) {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
  }
  function getRatingInfo(item) {
    const ratings = item?.ratings && typeof item.ratings === 'object' ? item.ratings : {};
    const values = Object.values(ratings).map(Number).filter(v => !isNaN(v) && v >= 1 && v <= 5);
    if (values.length === 0) return { average: Number(item?.rating || 0), count: Number(item?.ratingCount || 0) };
    const sum = values.reduce((t, v) => t + v, 0);
    return { average: sum / values.length, count: values.length };
  }
  function sortDoctorsList(list) {
    return [...list].sort((a, b) => {
      const specComp = String(a.specialty || '').localeCompare(String(b.specialty || ''), 'ar');
      if (specComp !== 0) return specComp;
      return String(a.name || '').localeCompare(String(b.name || ''), 'ar');
    });
  }

  function Toast({ notification }) {
    if (!notification) return null;
    return (
      <div className={`fixed top-6 left-1/2 -translate-x-1/2 px-6 py-3 rounded-full shadow-2xl border z-[110] flex items-center gap-2 font-bold animate-fadeIn w-max max-w-[90%] ${notification.type === 'success' ? 'bg-indigo-500 text-white border-indigo-400' : 'bg-red-50 dark:bg-slate-800 text-red-500 dark:text-red-400 border-red-200 dark:border-red-500/50'}`}>
        {notification.type === 'success' ? <CheckCircle2 size={18} /> : <AlertTriangle size={18} />}
        <span className="text-sm">{notification.msg}</span>
      </div>
    );
  }

  function CustomModal({ isOpen, title, message, onConfirm, onCancel, isDestructive, confirmText }) {
    if (!isOpen) return null;
    return (
      <div className="fixed inset-0 z-[100] flex items-center justify-center bg-slate-900/50 dark:bg-slate-950/80 backdrop-blur-sm animate-fadeIn p-4">
        <div className="glass-panel w-full max-w-sm rounded-[2rem] p-6 shadow-2xl relative overflow-hidden">
          <div className={`w-12 h-12 rounded-full flex items-center justify-center mb-4 mx-auto ${isDestructive ? 'bg-red-100 dark:bg-red-500/20 text-red-500 dark:text-red-400' : 'bg-indigo-100 dark:bg-indigo-500/20 text-indigo-600 dark:text-indigo-400'}`}>
            {isDestructive ? <AlertTriangle size={24} /> : <Info size={24} />}
          </div>
          <h3 className="text-xl font-black text-center mb-2">{title}</h3>
          <p className="text-slate-500 dark:text-slate-400 text-center mb-6 text-sm leading-relaxed whitespace-pre-line">{message}</p>
          <div className="flex gap-3">
            <button onClick={onCancel} className="flex-1 py-3 rounded-xl bg-slate-100 dark:bg-slate-800 border text-slate-600 dark:text-slate-300 font-bold">إلغاء</button>
            <button onClick={onConfirm} className={`flex-1 py-3 rounded-xl font-bold transition shadow-lg ${isDestructive ? 'bg-red-500 text-white hover:bg-red-600' : 'bg-indigo-500 text-white hover:bg-indigo-600'}`}>{confirmText}</button>
          </div>
        </div>
      </div>
    );
  }

  function AdminHeader({ isDark, toggleTheme, view, setView }) {
    const handleLogout = () => signOut(auth);
    const isSubView = ['donors','medicines','reports','doctors','requests','duty'].includes(view);
    return (
      <div className="sticky top-0 z-40 bg-white/90 dark:bg-slate-900/90 backdrop-blur-lg border-b border-slate-200 dark:border-slate-800 px-4 py-4 flex justify-between items-center mb-6 shadow-sm">
        {isSubView ? (
          <button onClick={() => setView('dashboard')} className="w-10 h-10 glass-panel rounded-full flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-indigo-500"><ArrowRight size={20} /></button>
        ) : (
          <button onClick={handleLogout} className="w-10 h-10 glass-panel rounded-full flex items-center justify-center text-red-500 hover:text-red-600 transition bg-red-50 dark:bg-slate-800"><LogOut size={18} /></button>
        )}
        <div className="text-center font-black text-indigo-500 dark:text-indigo-400 text-xl tracking-widest">Zomraa Admin</div>
        <button onClick={toggleTheme} className="w-10 h-10 glass-panel rounded-full flex items-center justify-center text-slate-500 dark:text-slate-400">
          {isDark ? <Sun size={20} /> : <Moon size={20} />}
        </button>
      </div>
    );
  }

  function AdminBottomNav({ view, setView }) {
    const isSubView = ['donors','medicines','reports','doctors','requests','duty'].includes(view);
    if (isSubView) return null;
    return (
      <div className="fixed bottom-0 left-0 w-full bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border-t border-slate-200 dark:border-slate-800 z-50 pb-[env(safe-area-inset-bottom)]">
        <div className="flex justify-around items-center h-16 px-2">
          <button onClick={() => setView('dashboard')} className={`flex flex-col items-center gap-1 w-[16%] ${view==='dashboard'?'text-indigo-500':'text-slate-400'}`}><LayoutDashboard size={20}/><span className="text-[10px] font-bold">الرئيسية</span></button>
          <button onClick={() => setView('pharmacies')} className={`flex flex-col items-center gap-1 w-[16%] ${view==='pharmacies'?'text-indigo-500':'text-slate-400'}`}><Stethoscope size={20}/><span className="text-[10px] font-bold">صيدليات</span></button>
          <button onClick={() => setView('duty')} className={`flex flex-col items-center gap-1 w-[16%] ${view==='duty'?'text-indigo-500':'text-slate-400'}`}><Calendar size={20}/><span className="text-[10px] font-bold">مناوبات</span></button>
          <button onClick={() => setView('requests')} className={`flex flex-col items-center gap-1 w-[16%] ${view==='requests'?'text-indigo-500':'text-slate-400'}`}><MessageSquare size={20}/><span className="text-[10px] font-bold">الطلبات</span></button>
          <button onClick={() => setView('notifications')} className={`flex flex-col items-center gap-1 w-[16%] ${view==='notifications'?'text-indigo-500':'text-slate-400'}`}><Activity size={20}/><span className="text-[10px] font-bold">النشاط</span></button>
          <button onClick={() => setView('broadcast')} className={`flex flex-col items-center gap-1 w-[16%] ${view==='broadcast'?'text-indigo-500':'text-slate-400'}`}><Send size={20}/><span className="text-[10px] font-bold">إعلانات</span></button>
        </div>
      </div>
    );
  }

  function DashboardView({ donors=[], pharmacies=[], doctors=[], medicines=[], reports=[], adminRequests=[], setView }) {
    const safeDonors = Array.isArray(donors) ? donors.length : 0;
    const safePharm = Array.isArray(pharmacies) ? pharmacies.length : 0;
    const safeDoctors = Array.isArray(doctors) ? doctors.length : 0;
    const safeMed = Array.isArray(medicines) ? medicines.length : 0;
    const safeReports = Array.isArray(reports) ? reports.length : 0;
    const safeRequests = Array.isArray(adminRequests) ? adminRequests.length : 0;
    return (
      <div className="animate-fadeIn px-4 md:px-6">
        <h2 className="text-xl font-black text-slate-800 dark:text-white mb-6">لوحة الإحصائيات والإدارة</h2>
        <div className="grid grid-cols-2 gap-4">
          <div onClick={() => setView('donors')} className="glass-panel p-6 rounded-3xl flex flex-col items-center justify-center text-center cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-800/80 transition"><Users size={36} className="text-indigo-500 mb-2"/><span className="text-3xl font-black">{safeDonors}</span><span className="text-sm font-bold mt-1">المتبرعين</span></div>
          <div onClick={() => setView('medicines')} className="glass-panel p-6 rounded-3xl flex flex-col items-center justify-center text-center cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-800/80 transition"><Pill size={36} className="text-orange-500 mb-2"/><span className="text-3xl font-black">{safeMed}</span><span className="text-sm font-bold mt-1">طلبات الأدوية</span></div>
          <div onClick={() => setView('reports')} className="glass-panel p-6 rounded-3xl flex flex-col items-center justify-center text-center cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-800/80 transition"><ShieldAlert size={36} className="text-red-500 mb-2"/><span className="text-3xl font-black">{safeReports}</span><span className="text-sm font-bold mt-1">البلاغات</span></div>
          <div onClick={() => setView('requests')} className="glass-panel p-6 rounded-3xl flex flex-col items-center justify-center text-center cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-800/80 transition"><MessageSquare size={36} className="text-blue-500 mb-2"/><span className="text-3xl font-black">{safeRequests}</span><span className="text-sm font-bold mt-1">الطلبات والرسائل</span></div>
          <div onClick={() => setView('pharmacies')} className="glass-panel p-6 rounded-3xl flex flex-col items-center justify-center text-center cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-800/80 transition"><Stethoscope size={36} className="text-emerald-500 mb-2"/><span className="text-3xl font-black">{safePharm}</span><span className="text-sm font-bold mt-1">الصيدليات</span></div>
          <div onClick={() => setView('doctors')} className="glass-panel p-6 rounded-3xl flex flex-col items-center justify-center text-center cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-800/80 transition"><HeartPulse size={36} className="text-blue-500 mb-2"/><span className="text-3xl font-black">{safeDoctors}</span><span className="text-sm font-bold mt-1">الأطباء</span></div>
        </div>
      </div>
    );
  }
  
  // ======================== PharmaciesManager ========================
  function PharmaciesManager({ pharmacies = [], showNotification, confirmAction }) {
    const [showForm, setShowForm] = useState(false);
    const [editingId, setEditingId] = useState(null);
    const [name, setName] = useState(''); const [phone, setPhone] = useState('');
    const [address, setAddress] = useState(''); const [mapLink, setMapLink] = useState('');
    const [openTime, setOpenTime] = useState('08:00'); const [closeTime, setCloseTime] = useState('22:00');
    const [loading, setLoading] = useState(false);
    const safePharmacies = Array.isArray(pharmacies) ? pharmacies : [];

    const resetForm = () => {
      setShowForm(false); setEditingId(null);
      setName(''); setPhone(''); setAddress(''); setMapLink('');
      setOpenTime('08:00'); setCloseTime('22:00');
    };
    const handleEditClick = (pharmacy) => {
      setEditingId(pharmacy.id); setName(pharmacy.name || ''); setPhone(pharmacy.phone || '');
      setAddress(pharmacy.address || ''); setMapLink(pharmacy.mapLink || '');
      setOpenTime(pharmacy.openTime || '08:00'); setCloseTime(pharmacy.closeTime || '22:00');
      setShowForm(true); window.scrollTo({ top: 0, behavior: 'smooth' });
    };
    const handleSubmit = async (e) => {
      e.preventDefault();
      if (!name.trim() || !address.trim()) { showNotification('error', 'أدخل الاسم والعنوان'); return; }
      setLoading(true);
      try {
        const data = { name: name.trim(), phone: phone.trim(), address: address.trim(), mapLink: mapLink.trim(), openTime, closeTime, updatedAt: serverTimestamp() };
        if (editingId) {
          await updateDoc(doc(db, PHARMACIES_COLLECTION, editingId), data);
          showNotification('success', 'تم تعديل الصيدلية');
        } else {
          data.createdAt = serverTimestamp();
          await addDoc(collection(db, PHARMACIES_COLLECTION), data);
          showNotification('success', 'تمت إضافة الصيدلية');
        }
        resetForm();
      } catch { showNotification('error', 'حدث خطأ'); }
      finally { setLoading(false); }
    };
    const deletePharmacy = (id) => {
      confirmAction("حذف صيدلية", "هل تريد حذف هذه الصيدلية؟", "حذف", async () => {
        try { await deleteDoc(doc(db, PHARMACIES_COLLECTION, id)); showNotification('success', 'تم الحذف'); }
        catch { showNotification('error', 'فشل الحذف'); }
      }, true);
    };

    return (
      <div className="animate-fadeIn px-4 md:px-6 pb-6">
        <div className="flex justify-between items-center mb-6">
          <h2 className="text-xl font-black text-slate-800 dark:text-white"><Stethoscope className="inline ml-2 text-emerald-500"/> إدارة الصيدليات</h2>
          <button onClick={() => setShowForm(!showForm)} className="bg-emerald-500 text-white p-2 rounded-xl shadow-lg">
            {showForm ? <X size={20} /> : <Plus size={20} />}
          </button>
        </div>
        {showForm && (
          <form onSubmit={handleSubmit} className="glass-panel p-5 rounded-3xl mb-8 flex flex-col gap-4 animate-fadeIn">
            <div className="flex justify-between items-center">
              <button type="button" onClick={resetForm} className="text-xs text-slate-500 bg-slate-100 px-3 py-1 rounded-lg">إلغاء</button>
              <h3 className="font-bold text-emerald-600 flex items-center gap-2"><Plus size={18}/> {editingId ? 'تعديل صيدلية' : 'إضافة صيدلية جديدة'}</h3>
            </div>
            <input type="text" placeholder="اسم الصيدلية" value={name} onChange={e => setName(e.target.value)} className="custom-input p-3 rounded-xl text-right" required />
            <div className="grid grid-cols-2 gap-4">
              <input type="text" placeholder="العنوان" value={address} onChange={e => setAddress(e.target.value)} className="custom-input p-3 rounded-xl text-right" required />
              <input type="tel" placeholder="رقم الهاتف" value={phone} onChange={e => setPhone(e.target.value)} className="custom-input p-3 rounded-xl text-right" dir="ltr" />
            </div>
            <input type="url" placeholder="رابط الخريطة" value={mapLink} onChange={e => setMapLink(e.target.value)} className="custom-input p-3 rounded-xl text-right" dir="ltr" />
            <div className="grid grid-cols-2 gap-4">
              <div><label className="text-xs block mb-1">وقت الافتتاح</label><input type="time" value={openTime} onChange={e => setOpenTime(e.target.value)} className="custom-input p-3 rounded-xl text-center w-full" /></div>
              <div><label className="text-xs block mb-1">وقت الإغلاق</label><input type="time" value={closeTime} onChange={e => setCloseTime(e.target.value)} className="custom-input p-3 rounded-xl text-center w-full" /></div>
            </div>
            <button type="submit" disabled={loading} className="bg-emerald-500 text-white font-bold p-3 rounded-xl hover:bg-emerald-600 disabled:opacity-50 flex justify-center gap-2">
              {loading ? <Loader2 className="animate-spin" /> : (editingId ? <><Edit size={16} /> تحديث</> : 'حفظ الصيدلية')}
            </button>
          </form>
        )}
        <div className="space-y-3">
          {safePharmacies.length === 0 ? <p className="text-center py-10 text-slate-500">لا توجد صيدليات.</p> :
            safePharmacies.map(p => (
              <div key={p.id} className="glass-panel p-4 rounded-2xl flex justify-between items-start">
                <div className="flex items-center gap-2">
                  <button onClick={() => deletePharmacy(p.id)} className="p-2 bg-red-50 text-red-500 rounded-lg"><Trash2 size={16} /></button>
                  <button onClick={() => handleEditClick(p)} className="p-2 bg-indigo-50 text-indigo-500 rounded-lg"><Edit size={16} /></button>
                </div>
                <div className="text-right flex-1 pr-2">
                  <h4 className="font-black flex items-center justify-end gap-1">
                    {p.mapLink && <a href={p.mapLink} target="_blank" className="text-blue-500"><Map size={14} /></a>}
                    {p.name || 'بدون اسم'}
                  </h4>
                  <p className="text-xs text-slate-500"><MapPin size={10} /> {p.address || '---'}</p>
                  {p.phone && <p className="text-xs" dir="ltr"><Phone size={10} /> {p.phone}</p>}
                  <p className="text-xs text-indigo-500"><Clock size={10} /> {p.openTime || '08:00'} - {p.closeTime || '22:00'}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    );
  }

  // ======================== DutyManager ========================
  function DutyManager({ pharmacies = [], showNotification }) {
    const [selectedDate, setSelectedDate] = useState(getLocalDateString());
    const [selectedPharmacies, setSelectedPharmacies] = useState([]);
    const [loading, setLoading] = useState(false);
    const [dutyRecords, setDutyRecords] = useState([]);
    const safePharmacies = Array.isArray(pharmacies) ? pharmacies : [];

    useEffect(() => {
      const unsub = onSnapshot(collection(db, DUTY_DATES_COLLECTION), (snap) => {
        setDutyRecords(snap.docs.map(d => ({ id: d.id, ...d.data() })));
      });
      return () => unsub();
    }, []);

    useEffect(() => {
      const record = dutyRecords.find(r => r.date === selectedDate);
      setSelectedPharmacies(record ? record.pharmacyIds || [] : []);
    }, [selectedDate, dutyRecords]);

    const togglePharmacy = (id) => {
      setSelectedPharmacies(prev => prev.includes(id) ? prev.filter(x => x !== id) : [...prev, id]);
    };

    const saveDuty = async () => {
      setLoading(true);
      try {
        const existing = dutyRecords.find(r => r.date === selectedDate);
        if (existing) {
          await updateDoc(doc(db, DUTY_DATES_COLLECTION, existing.id), {
            pharmacyIds: selectedPharmacies, updatedAt: serverTimestamp()
          });
        } else {
          await addDoc(collection(db, DUTY_DATES_COLLECTION), {
            date: selectedDate, pharmacyIds: selectedPharmacies, createdAt: serverTimestamp()
          });
        }
        showNotification('success', 'تم حفظ المناوبات');
      } catch { showNotification('error', 'فشل الحفظ'); }
      finally { setLoading(false); }
    };

    return (
      <div className="animate-fadeIn px-4 md:px-6 pb-6">
        <h2 className="text-xl font-black text-slate-800 dark:text-white mb-6"><Calendar className="inline ml-2 text-indigo-500"/> إدارة المناوبات</h2>
        <div className="glass-panel p-4 rounded-2xl mb-6">
          <label className="text-sm font-bold block mb-2">اختر التاريخ</label>
          <input type="date" value={selectedDate} onChange={e => setSelectedDate(e.target.value)} className="custom-input p-3 rounded-xl w-full text-center" />
        </div>
        <div className="space-y-3 mb-6">
          {safePharmacies.length === 0 ? <p className="text-center py-4 text-slate-500">لا توجد صيدليات</p> :
            safePharmacies.map(p => (
              <div key={p.id} onClick={() => togglePharmacy(p.id)}
                   className={`glass-panel p-4 rounded-2xl flex justify-between items-center cursor-pointer hover:border-indigo-300 transition ${selectedPharmacies.includes(p.id) ? 'border-2 border-indigo-500 bg-indigo-50 dark:bg-indigo-900/20' : ''}`}>
                <div className={`w-5 h-5 rounded border-2 flex items-center justify-center ${selectedPharmacies.includes(p.id) ? 'bg-indigo-500 border-indigo-500' : 'border-slate-300'}`}>
                  {selectedPharmacies.includes(p.id) && <CheckCircle2 size={14} className="text-white" />}
                </div>
                <div className="text-right">
                  <h4 className="font-bold">{p.name || 'بدون اسم'}</h4>
