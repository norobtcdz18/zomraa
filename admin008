                    <p className="text-xs text-slate-600 mt-1 whitespace-pre-line">{n.body || ''}</p>
                  </div>
                  {!isGlobal && n.fromUserId !== 'ADMIN' && (
                    <div className="mt-2 flex justify-end">
                      <button onClick={() => setReplyTo(n)} className="text-xs bg-indigo-100 text-indigo-600 px-3 py-1 rounded-lg flex items-center gap-1 hover:bg-indigo-200">
                        <Reply size={12} /> رد
                      </button>
                    </div>
                  )}
                </div>
              );
            })
          }
        </div>
        {replyTo && (
          <div className="fixed inset-0 z-[110] flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
