  // ======================== BroadcastView ========================
  function BroadcastView({ donors = [], showNotification, confirmAction }) {
    const [title, setTitle] = useState('');
    const [body, setBody] = useState('');
    const [target, setTarget] = useState('all');
    const [selectedBloodType, setSelectedBloodType] = useState('');
    const [loading, setLoading] = useState(false);
    const safeDonors = Array.isArray(donors) ? donors : [];
    const bloodTypes = ['A+', 'A-', 'B+', 'B-', 'O+', 'O-', 'AB+', 'AB-'];

    const targetDonors = useMemo(() => {
      if (target === 'all') return safeDonors;
      return safeDonors.filter(d => d.bloodType === selectedBloodType);
    }, [safeDonors, target, selectedBloodType]);

    const handleBroadcast = async (e) => {
      e.preventDefault();
      if (!title.trim() || !body.trim()) { showNotification('error', 'أدخل العنوان والنص'); return; }
      if (target === 'specific' && !selectedBloodType) { showNotification('error', 'اختر فصيلة الدم'); return; }
      confirmAction("تأكيد الإرسال", `إرسال إلى ${targetDonors.length} متبرع${target !== 'all' ? ` (فصيلة ${selectedBloodType})` : ''}؟`, "نعم، أرسل", async () => {
        setLoading(true);
        try {
          const promises = targetDonors.map(d => addDoc(collection(db, NOTIFICATIONS_COLLECTION), {
            toUserId: d.id, fromUserId: 'ADMIN', title: title.trim(), body: body.trim(), type: 'global', read: false, createdAt: serverTimestamp()
          }));
          await Promise.all(promises);
          showNotification('success', 'تم الإرسال');
          setTitle(''); setBody('');
        } catch { showNotification('error', 'فشل الإرسال'); }
        finally { setLoading(false); }
      }, false);
    };

    return (
      <div className="animate-fadeIn px-4 md:px-6 pb-6">
        <h2 className="text-xl font-black text-slate-800 dark:text-white mb-6"><Send className="inline ml-2 text-indigo-500"/> الإعلانات الجماعية</h2>
        <div className="glass-panel p-5 rounded-3xl mb-6">
          <form onSubmit={handleBroadcast} className="flex flex-col gap-4">
            <div>
              <label className="text-sm font-bold block mb-2">المستهدفون</label>
              <select value={target} onChange={e => setTarget(e.target.value)} className="custom-input w-full p-3 rounded-xl text-center">
                <option value="all">جميع المتبرعين</option>
                <option value="specific">فصيلة دم محددة</option>
              </select>
            </div>
            {target === 'specific' && (
              <div>
                <label className="text-sm font-bold block mb-2">اختر الفصيلة</label>
                <select value={selectedBloodType} onChange={e => setSelectedBloodType(e.target.value)} className="custom-input w-full p-3 rounded-xl text-center">
                  <option value="">-- اختر --</option>
                  {bloodTypes.map(bt => <option key={bt} value={bt}>{bt}</option>)}
                </select>
              </div>
            )}
            <input type="text" placeholder="عنوان الإشعار" value={title} onChange={e => setTitle(e.target.value)} className="custom-input p-3 rounded-xl" required />
            <textarea placeholder="نص الإشعار" value={body} onChange={e => setBody(e.target.value)} className="custom-input p-4 rounded-xl h-28 resize-none" required></textarea>
            <button type="submit" disabled={loading || (target === 'specific' && !selectedBloodType)} className="w-full bg-indigo-500 text-white p-3 rounded-xl font-bold disabled:opacity-50 flex justify-center gap-2">
              {loading ? <Loader2 className="animate-spin" /> : <><Send size={16} /> إرسال إلى {targetDonors.length} متبرع</>}
            </button>
          </form>
        </div>
      </div>
    );
  }

  // ======================== NotificationsLogView (مع الرد على الإشعارات) ========================
  function NotificationsLogView({ notifications = [], donors = [], showNotification }) {
    const [replyTo, setReplyTo] = useState(null);
    const [replyText, setReplyText] = useState('');
    const [sendingReply, setSendingReply] = useState(false);
    const safeNotifications = Array.isArray(notifications) ? notifications : [];
    const safeDonors = Array.isArray(donors) ? donors : [];

    const grouped = useMemo(() => {
      const result = []; const seen = new Set();
      safeNotifications.forEach(n => {
        if (n.type === 'global') {
          const key = `${n.title}_${n.body}`;
          if (!seen.has(key)) { result.push({...n, isGrouped: true}); seen.add(key); }
        } else result.push(n);
      });
      return result;
    }, [safeNotifications]);

    const handleSendReply = async () => {
      if (!replyTo || !replyText.trim()) return;
      setSendingReply(true);
      try {
        await addDoc(collection(db, NOTIFICATIONS_COLLECTION), {
          toUserId: replyTo.fromUserId,
          fromUserId: 'ADMIN',
          title: 'رد من الإدارة',
          body: replyText.trim(),
          type: 'info',
          read: false,
          createdAt: serverTimestamp()
        });
        showNotification('success', 'تم إرسال الرد');
        setReplyTo(null);
        setReplyText('');
      } catch { showNotification('error', 'فشل الإرسال'); }
      finally { setSendingReply(false); }
    };

    return (
      <div className="animate-fadeIn px-4 md:px-6 pb-6">
